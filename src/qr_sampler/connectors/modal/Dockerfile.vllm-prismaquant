# Dockerfile for the Modal-hosted vLLM container that serves
# rdtand/Qwen3.6-27B-PrismaQuant-5.5bit-vllm on H100:1, on vLLM v0.20.0.
#
# This is the iter-17 "new engine type" profile. The existing
# Dockerfile.vllm (vLLM v0.17.0 + Qwen3.5-9B-FP8) is intentionally left
# untouched so the iter-15 stack stays a reliable fallback. Everything
# the operator can see — image, Volume mount paths, env vars, cmd-list
# — is keyed off PRISMAQUANT_* constants in app.py rather than the
# original MODEL_* constants.
#
# Why a separate Dockerfile rather than parameterising the existing one
# ---------------------------------------------------------------------
# 1. vLLM major upgrades carry collateral risk (PyTorch baseline,
#    CUDA toolkit, transformers compatibility, internal Python APIs the
#    monkey-patches in vllm_serve.py / vllm_patches.py hook). Pinning
#    the existing image's recipe to v0.17.0 lets us validate v0.20.0
#    in isolation; if 0.20 regresses on something we haven't planned
#    for, the iter-15 stack still ships.
# 2. Modal builds images from Dockerfile by hash. A single Dockerfile
#    rebuilt with a different `ARG VLLM_BASE_TAG` produces a new image
#    digest — which fragments snapshot reuse across the two profiles.
#    Separate files keep each profile's snapshot identity stable.
# 3. The PrismaQuant scheme requires VLLM_NVFP4_GEMM_BACKEND=
#    flashinfer-cutlass to be set as part of the snapshot input
#    surface. Adding that to the existing image's ENV block would
#    invalidate the iter-15 snapshot (and force an unnecessary cold-
#    cold rebuild) even when serving the 9B-FP8 model.

# vLLM v0.20.0 (released 2026-04-27 per upstream release notes). Key
# features for PrismaQuant:
#   * compressed-tensors loader recognises NVFP4 (W4A16Fp4) and MXFP8
#     (W8A8Mxfp8) schemes — the two PrismaQuant uses for weights and
#     select activations respectively.
#   * NVFP4 attention kernels via FlashInfer-cutlass (Hopper emulation
#     of Blackwell-native NVFP4).
#   * PyTorch 2.11 + CUDA 13.0 baseline (the base image carries
#     matching CUDA + PyTorch wheels, no additional install needed).
# v0.21.0 added more NVFP4 features but regressed Qwen3 MM-probe per
# auto-memory `iter15_demo_deploy` notes — v0.20.0 is the "newest
# known-stable" minor for our stack as of 2026-05-24.
ARG VLLM_BASE_TAG=v0.20.0
FROM vllm/vllm-openai:${VLLM_BASE_TAG}

# Env block mirrors Dockerfile.vllm v0.17.0 PLUS the PrismaQuant-specific
# VLLM_NVFP4_GEMM_BACKEND pin. The other vars are unchanged because they
# affect generic vLLM behaviour (logging, NCCL monitor silencing, snapshot-
# compatible inductor mode) that's still relevant at v0.20.
#
# VLLM_NVFP4_GEMM_BACKEND=flashinfer-cutlass — the PrismaQuant model card
# documents this as the recipe-pinned backend. Without it vLLM picks one
# at engine init from the available NVFP4 GEMM backends; on H100 the
# flashinfer-cutlass path is what the recipe was measured against.
# Pinning it here freezes the choice into the snapshot input surface so
# a future vLLM upgrade with a different auto-selection heuristic does
# not silently change cold-start behaviour.
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    VLLM_LOGGING_LEVEL=INFO \
    VLLM_SERVER_DEV_MODE=1 \
    HF_HUB_ENABLE_HF_TRANSFER=1 \
    TORCH_NCCL_ENABLE_MONITORING=0 \
    TORCH_NCCL_HEARTBEAT_TIMEOUT_SEC=86400 \
    TORCH_CPP_LOG_LEVEL=ERROR \
    TORCHINDUCTOR_COMPILE_THREADS=1 \
    VLLM_NVFP4_GEMM_BACKEND=flashinfer-cutlass

# Python symlink (same rationale as Dockerfile.vllm — Modal's image-
# attach step probes a bare `python`).
RUN ln -sf "$(command -v python3.12 || command -v python3 || command -v python)" \
        /usr/local/bin/python \
    && python --version

WORKDIR /opt/qr-sampler

# qr-sampler source + runtime deps. Mirrors Dockerfile.vllm. Modal's
# image-attach step caches by layer hash, so these layers will only
# rebuild when pyproject.toml or src/ change.
COPY pyproject.toml ./
COPY src/ ./src/
RUN pip install --no-cache-dir . \
    && pip install --no-cache-dir \
        "huggingface_hub>=0.30" \
        "fastapi>=0.110" \
        "httpx>=0.27" \
        "grpcio>=1.62"

# apt deps for git (transformers @ pinned tag install) + cloudflared.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        git \
        curl \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# transformers pinning. vLLM 0.21 deprecates Transformers v4, so v0.20
# is the last minor that supports v4 — but our pin is v5.5.4 which
# works on both. The qwen3_5 GDN architecture entry needed for
# Qwen3_5ForCausalLM is in v5.5.x.
#
# mistral_common + huggingface_hub upgrades same as Dockerfile.vllm
# (transformers v5.5.4 lazily imports tokenization_mistral_common and
# requires huggingface_hub>=0.30).
RUN pip install --no-cache-dir --no-deps \
        "transformers==5.5.4" \
    && pip install --no-cache-dir --upgrade \
        "huggingface_hub>=0.30.0" \
        "mistral_common>=1.10"

# cloudflared sidecar (same install pattern as Dockerfile.vllm). The
# sidecar binary is identical for both profiles; the version is
# captured in the build log so an audit can confirm which bytes are
# in the snapshot input surface.
RUN set -eux \
    && curl -fsSL \
        https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64.deb \
        -o /tmp/cloudflared.deb \
    && echo "cloudflared.sha256 $(sha256sum /tmp/cloudflared.deb | cut -d' ' -f1)" \
    && dpkg -i /tmp/cloudflared.deb \
    && echo "cloudflared.version $(cloudflared --version 2>&1 | head -1)" \
    && rm /tmp/cloudflared.deb

# qr-sampler runtime QR_* defaults. Mirrors Dockerfile.vllm — the
# Modal Secret qr-sampler-prod overrides any of these at runtime.
ENV QR_ENTROPY_SOURCE_TYPE=quantum_grpc \
    QR_PREINIT_ENTROPY_SOURCES=quantum_grpc,system \
    QR_FALLBACK_MODE=system \
    QR_SAMPLE_COUNT=12800 \
    QR_GRPC_SERVER_ADDRESS=127.0.0.1:50051 \
    QR_GRPC_MODE=unary \
    QR_GRPC_METHOD_PATH=/qrng.QuantumRNG/GetRandomBytes \
    QR_GRPC_STREAM_METHOD_PATH= \
    QR_GRPC_API_KEY_HEADER=api-key \
    QR_PRESET=creative_sampling

# Reset ENTRYPOINT so Modal's @modal.enter controls process start.
ENTRYPOINT []
CMD ["python", "-m", "deployments.modal.vllm_serve"]
