# Environment variables for qr-sampler stack
# Engine: {{ engine.name }}
# Model: {{ model }}
# Entropy source: {{ entropy_source.name }}

# Inference engine settings
MODEL={{ model }}
INFERENCE_PORT=8000
{% for key, value in engine_config.items() %}
{{ key | upper }}={{ value }}
{% endfor %}

# Sampling preset: server-draw mode (qr_purity.PurityService).
# Degrades fail-safe to local byte amplification when the entropy
# server only implements EntropyService.
QR_PRESET=qthought_purity

# Entropy source settings
{% if needs_entropy_server %}
ENTROPY_SERVER_PORT=50051
ENTROPY_SERVER=simple_urandom_server.py
QR_GRPC_SERVER_ADDRESS=entropy-server:50051
{% endif %}
{% for key, value in entropy_config.items() %}
QR_{{ key | upper }}={{ value }}
{% endfor %}
