# deployments/modal/.env.example
#
# Reference for the env vars the Modal containers expect. The actual values
# are NOT loaded from this file at runtime — they live in two Modal Secrets:
#
#   - qr-sampler-prod   (everything below except HF_TOKEN)
#   - hf-token          (HF_TOKEN only)
#
# Provision both via `modal secret create` (see modal_secrets.md). Use this
# file to track what each value should be, and as a checklist for the
# operator when populating the secrets.

# =============================================================================
# Container image pins (built into the image, not env-injected)
# =============================================================================
# Pinned at build time via Dockerfile ARG. Update alongside the Dockerfile
# when bumping versions.
#
# VLLM_BASE_TAG=v0.6.6              # vLLM image tag with B200 + FP8 KV

# =============================================================================
# vllm_qr — entropy / qr-sampler config
# =============================================================================
QR_ENTROPY_SOURCE_TYPE=quantum_grpc
QR_PREINIT_ENTROPY_SOURCES=quantum_grpc,system
QR_FALLBACK_MODE=error
QR_SAMPLE_COUNT=13312

# =============================================================================
# vllm_qr — firefly-1 gRPC client
# =============================================================================
QR_GRPC_SERVER_ADDRESS=10.0.0.115:50051
QR_GRPC_MODE=unary
QR_GRPC_METHOD_PATH=/qrng.QuantumRNG/GetRandomBytes
QR_GRPC_STREAM_METHOD_PATH=
QR_GRPC_API_KEY=REPLACE_VIA_MODAL_SECRET
QR_GRPC_API_KEY_HEADER=api-key
QR_GRPC_TIMEOUT_MS=5000

# =============================================================================
# vllm_qr — circuit breaker (qr-sampler defaults; override only if needed)
# =============================================================================
# QR_CB_FAILURE_THRESHOLD=3
# QR_CB_LATENCY_MULTIPLIER=1.5

# =============================================================================
# vllm_qr — models
# =============================================================================
VLLM_MODELS=gemma-4-31b-reasoning,qwen-3.6-27b-reasoning
VLLM_DEFAULT_MODEL=gemma-4-31b-reasoning
VLLM_MAX_MODEL_LEN=65536
VLLM_GPU_MEMORY_UTILIZATION_PER_ENGINE=0.45

# Pinned Hugging Face revisions for reproducible weight downloads. Leave
# blank to use the latest revision at `modal run ... download_weights` time.
GEMMA_REVISION=
QWEN_REVISION=

# =============================================================================
# vllm_qr — bearer auth (rolling-secret vector, Pre-flight §11.4)
# =============================================================================
# Comma-separated rolling-secret vector. The signer (OWUI's OPENAI_API_KEY on
# the entropic.science Replit deployment) uses the FIRST entry; this Modal
# app's `_verify_bearer` (see vllm_serve.py) accepts a match against ANY
# entry, so rotation = prepend new → redeploy at leisure → remove old.
#
# A single Modal Secret entry is shared with three readers:
#   - entropic.science api-server (preflightAllowance / debitAllowance HMAC verifier)
#   - the OWUI plugin's HMAC signer
#   - VllmQr's bearer-token verifier (this app)
#
# Generate with: openssl rand -base64 32
SERVICE_TOKEN_SECRETS=REPLACE_VIA_MODAL_SECRET

# Smoke-test / local-dev escape hatch. When SERVICE_TOKEN_SECRETS is empty the
# container fails closed (503) on every request UNLESS this flag is set to the
# literal string "1". Never set this in production. See modal_secrets.md →
# "Unauthenticated-inference opt-in".
# ALLOW_UNAUTHENTICATED_INFERENCE=1

# =============================================================================
# entropic.science API integration (filter + pipe consume this)
# =============================================================================
# Used by the qr-sampler OWUI plugins (qr_sampler_filter.py + qr_comparison_pipe.py)
# when they live in the entropic.science Replit OWUI artifact. The plugins
# call back into entropic.science/api for allowance preflight/debit + the
# conversation upsert.
ENTROPIC_API_BASE_URL=https://entropic.science/api

# =============================================================================
# Hugging Face (lives in the `hf-token` Modal Secret, NOT qr-sampler-prod)
# =============================================================================
HF_TOKEN=REPLACE_VIA_MODAL_SECRET
