# =============================================================================
# qr-server.env  —  environment for the SHARED qr-sampler vLLM engine
# =============================================================================
# This is a TEMPLATE. Copy to the real path and fill in every CHANGEME_ value:
#
#     sudo install -D -m 600 qr-server.env.example /etc/qr-server/qr-server.env
#     sudo nano /etc/qr-server/qr-server.env
#
# Loaded by qr-sampler-vllm.service via
# `EnvironmentFile=/etc/qr-server/qr-server.env`. Keep it mode 0600 — it holds
# the shared vLLM's qbert0g API key. NEVER commit the filled-in copy.
#
# This env configures the SHARED inference engine ONLY. The apps (qthought,
# owui) keep their own env files with their own qbert0g keys and their own
# per-lane qr_preset defaults; they reach this engine purely over the OpenAI API
# on 127.0.0.1:8000.
# =============================================================================

# ── Model ────────────────────────────────────────────────────────────────────
# Path to the single shared checkpoint on this box, and the served-model-name
# every client sends as `model`.  [HUMAN]
SHARED_MODEL_PATH=/opt/qr-server/models/shared-checkpoint
SHARED_MODEL_NAME=qr-llm

# ── Entropy transport (shared vLLM → shared qbert0g daemon) ──────────────────
# The primary source. `quantum_grpc` draws from the co-located qbert0g daemon.
QR_ENTROPY_SOURCE_TYPE=quantum_grpc

# Pre-initialise ONE pipeline per source listed here. It MUST list every source
# any lane can select per-request via qr_entropy_source_type, or an un-preinit'd
# value is rejected cleanly. `system` is the labelled os.urandom fallback leg;
# keep it here so a request can run a quantum-vs-PRNG comparison and so fallback
# is always available. (spec §3.3) Named instances declared in
# QR_ENTROPY_SOURCE_INSTANCES below are ALWAYS pre-initialised (union), listing
# them here is optional documentation.
QR_PREINIT_ENTROPY_SOURCES=quantum_grpc,system,qbert_prng_uniform,qbert_prng_markov

# Named entropy-source instances (JSON): instance_name -> {"type": <source
# type>, <infrastructure overrides>}. Each instance gets its own pre-init'd
# pipeline, selectable per-request via qr_entropy_source_type=<instance name>,
# and its name is carried end-to-end (TokenSamplingRecord.entropy_source_used,
# degraded-log legs, status-file primary_name) so a PRNG lane is loudly
# labelled as PRNG even though it rides the quantum_grpc transport. The two
# lanes below draw from Qbert0G's prng_uniform / prng_markov control sources —
# provision one API key per lane, each bound to the matching control device:
#   qbert0g keys create --name qr-sampler-prng-uniform --device prng_uniform ...
#   qbert0g keys create --name qr-sampler-prng-markov  --device prng_markov ...
# Allowed override keys: grpc_server_address, grpc_api_key, grpc_mode,
# grpc_timeout_ms, grpc_retry_count. Unknown keys or an instance name that
# shadows a source type fail startup loudly.  [HUMAN: paste the two keys]
QR_ENTROPY_SOURCE_INSTANCES={"qbert_prng_uniform":{"type":"quantum_grpc","grpc_api_key":"CHANGEME_key_bound_to_prng_uniform"},"qbert_prng_markov":{"type":"quantum_grpc","grpc_api_key":"CHANGEME_key_bound_to_prng_markov"}}

# Address of the LOCAL shared qbert0g. Prefer the UNIX socket; never off-box.
QR_GRPC_SERVER_ADDRESS=unix:///run/qbert0g/qbert0g.sock
QR_GRPC_MODE=unary
QR_GRPC_API_KEY_HEADER=api-key

# THE `qr-sampler` key from qbert0g.config.yaml — provision it bound to
# dragonfly-0 with max-bytes >= 2 MiB:
#   qbert0g keys create --name qr-sampler --device dragonfly-0 --max-bytes 2097152
# Paste the created key here.  [HUMAN]
QR_GRPC_API_KEY=CHANGEME_qr_sampler_qbert0g_key

# Pin every draw to the single draw card. dragonfly-0 serves draws; dragonfly-1
# is the coherence reference only (not in integration.sources). Without this pin
# an empty binding can resolve to dragonfly-1, which refuses (no draw fingerprint)
# and degrades to a labelled local draw.
QR_DRAW_SOURCE_ID=dragonfly-0

# If quantum draws fail, serve a LABELLED os.urandom leg (never silent — it flips
# entropy_is_fallback on the DrawMeta and the cross-process status file). This is
# an infrastructure field, pinned server-side; it is REJECTED in per-request
# extra_args by design (spec §6.1). Leave as `system`.
QR_FALLBACK_MODE=system

# The PROCESS-DEFAULT sampling profile for any request that carries no per-request
# vllm_xargs. The apps always send their own per-lane preset (qthought_think /
# qthought_voice / chat_light), so this only backstops a bare request. Keep the
# truncated think preset so even a bare request emits a parseable tool call.
QR_PRESET=qthought_think

# Cross-process entropy status file. qr-sampler writes degraded/recovered here so
# owui's qr_status.py and qthought's `entropy` event report entropy health
# WITHOUT touching the QRNG (spec §3.5). If you move it, point every reader at the
# same path. Unset → qr-sampler writes <tempdir>/qr_entropy_status.json (/tmp on
# Linux), which the app defaults already pair with.
QR_ENTROPY_STATUS_FILE=/tmp/qr_entropy_status.json
