# deployments/entropic-science/.env.example
#
# Local-dev mirror of the Modal env for end-to-end smoke testing.
# Copy to .env and fill in the placeholders.

# --- Model + Hugging Face ---
# Pick ONE for local dev — both is too much for a typical workstation GPU.
HF_MODEL=google/gemma-4-31b-reasoning
HF_TOKEN=

# --- Entropy: firefly-1 gRPC ---
QR_ENTROPY_SOURCE_TYPE=quantum_grpc
QR_PREINIT_ENTROPY_SOURCES=quantum_grpc,system
QR_GRPC_SERVER_ADDRESS=10.0.0.115:50051
QR_GRPC_MODE=unary
QR_GRPC_TIMEOUT_MS=5000
QR_GRPC_METHOD_PATH=/qrng.QuantumRNG/GetRandomBytes
# firefly-1 supports unary only — leave empty.
QR_GRPC_STREAM_METHOD_PATH=

QR_GRPC_API_KEY=YOUR_FIREFLY1_API_KEY_HERE
QR_GRPC_API_KEY_HEADER=api-key

# Match Modal's posture — surface QRNG outages instead of falling back.
QR_FALLBACK_MODE=error

# --- Sampling parameters ---
QR_SAMPLE_COUNT=13312
QR_LOG_LEVEL=summary

# --- vLLM internal API key (OWUI -> vLLM) ---
VLLM_API_KEY=dev-vllm-key

# --- entropic.science dev API (running on the Docker host) ---
# Adjust the port to match your local api-server's listen port.
ENTROPIC_API_BASE_URL=http://host.docker.internal:3001/api
SERVICE_TOKEN_SECRETS=dev-rolling-secret-1,dev-rolling-secret-0

# --- Ports (host-side) ---
VLLM_PORT=8000
OPEN_WEBUI_PORT=3000
OWUI_BASE_TAG=v0.5.0

# Set true when smoke-testing the trusted-header path against a local
# auth-proxy; leave false for plain OWUI local auth.
OPEN_WEBUI_AUTH=false
